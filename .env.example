# Service
SERVICE_NAME=growsim-backend
NODE_ENV=development
PORT=8080
LOG_LEVEL=debug
BODY_LIMIT=2mb
TRUST_PROXY=false
SHUTDOWN_TIMEOUT_MS=10000

# Security
# Use at least 32 random characters in production.
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# CORS
# Comma separated frontend origins, for example:
# CORS_ORIGINS=http://localhost:5173,https://app.example.com
CORS_ORIGINS=http://localhost:5173
CORS_ALLOW_CREDENTIALS=false

# Database
MONGODB_URI=mongodb://localhost:27017/growsim

# Web Push (VAPID)
# Generate once (example): npx web-push generate-vapid-keys
# VAPID_SUBJECT must be a URL or mailto, e.g. mailto:admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Server-side gameplay push evaluation scheduler
GAMEPLAY_PUSH_SCHEDULER_ENABLED=true
GAMEPLAY_PUSH_INTERVAL_SECONDS=300
GAMEPLAY_PUSH_BATCH_SIZE=100
GAMEPLAY_PUSH_QUIET_HOURS_ENABLED=true
GAMEPLAY_PUSH_QUIET_HOURS_START=22
GAMEPLAY_PUSH_QUIET_HOURS_END=7
GAMEPLAY_PUSH_QUIET_HOURS_TIMEZONE=UTC

# Admin seed (used by: npm run seed:admin)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=replace_with_a_strong_password
ADMIN_SEED_DISPLAY_NAME=Admin
